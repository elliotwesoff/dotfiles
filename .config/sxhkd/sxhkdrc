#!/bin/sh
#
# wm independent hotkeys

#
# program shortcuts
#

# my notes! i can't computer without my notes!
super + F1
  exec alacritty --command nvim -p \
          ~/dotfiles/.config/sxhkd/sxhkdrc \
          ~/dotfiles/.config/sxhkd/bspwm-sxhkdrc \
          ~/Documents/Notes/arch-notes.md \
          ~/dotfiles/.config/fish/config.fish \
          ~/dotfiles/.config/alacritty/alacritty.toml \
          ~/dotfiles/.config/nvim/lua/keymaps.lua

super + {Return,space,z,Delete}
  exec {alacritty,eww-toggle,eww-toggle,systemctl suspend}

super + shift + Return
  exec kitty

super + control + alt + shift + {Escape}
  exec {pkill Xorg}

super + alt + {t,f,p,d,Tab,r,m,w,o,a,e,space,0,1,2}
  exec {thunar, \
        firefox, \
        firefox --private-window, \
        discord, \
        alacritty --class Alacritty\,btop --command btop, \
        alacritty --class Alacritty\,ranger --command ranger,\
        alacritty --class Alacritty\,pulsemixer --command pulsemixer,\
        xdg-open https://web.whatsapp.com, \
        socials-kill, \
        rofi -show combi -combi-modes "drun" -modes combi, \
        rofi -modi emoji -show emoji, \
        rofi -show combi -combi-modes "window\,drun" -modes combi, \
        switch-mon off, \
        switch-mon internal, \
        switch-mon external}

XF86{LaunchA,Search,AudioMedia,ScreenSaver,MonBrightnessUp,MonBrightnessDown,AudioRaiseVolume,AudioLowerVolume,AudioMute}
  exec {rofi -show drun, \
        alacritty --class Alacritty\,ranger --command ranger,\
        alacritty --class Alacritty\,pulsemixer --command pulsemixer,\
        xset s activate, \
        blight set +5%, \
        blight set -5%, \
        pamixer -i 5, \
        pamixer -d 5, \
        pamixer -t}

Print
  flameshot gui

